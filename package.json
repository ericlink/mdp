{
  "name": "mdp",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "repository": "https://github.com/ericlink/mdp",
  "productName": "mdp",
  "description": "Markdown preview for local files with code highlighting, Mermaid, and live reload.",
  "author": "elink",
  "main": "./src/main.js",
  "keywords": [
    "markdown",
    "electron",
    "emoji",
    "syntax",
    "mermaid",
    "livereload",
    "live-reload"
  ],
  "scripts": {
    "dev-publish": "npm run package && rm -rf /Applications/mdp.app/ && mv ./out/mdp-darwin-x64/mdp.app /Applications/",
    "dev": "MDP_ALLOW_MULTI_INSTANCE=1 MDP_DEFAULT_FILE=./assets/example.md electron-forge start -- ./assets/example.md",
    "log": "tail -f /tmp/mdp-main.log",
    "dev-noarg": "MDP_ALLOW_MULTI_INSTANCE=1 electron-forge start",
    "dev-readme": "MDP_ALLOW_MULTI_INSTANCE=1 MDP_DEFAULT_FILE=./README.md electron-forge start -- ./README.md",
    "start": "MDP_ALLOW_MULTI_INSTANCE=1 MDP_DEFAULT_FILE=./assets/example.md electron-forge start -- ./assets/example.md",
    "package": "electron-forge package",
    "package:mac-internal": "MDP_INTERNAL=1 electron-forge package --platform=darwin --arch=arm64",
    "local-install": "test -d ./out/mdp-darwin-arm64/mdp.app && rm -rf /Applications/mdp.app && ditto ./out/mdp-darwin-arm64/mdp.app /Applications/mdp.app",
    "make": "electron-forge make",
    "make:mac-internal": "MDP_INTERNAL=1 electron-forge make --platform=darwin --arch=arm64",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\"",
    "apple-validate": "xcrun altool --verbose --validate-app -f ./out/make/zip/darwin/x64/mdp-darwin-x64-*.zip -t darwin -u eric.m.link@gmail.com --password $APPL_PASS",
    "apple-upload": "xcrun altool --verbose --upload-app -f ./out/make/zip/darwin/x64/mdp-darwin-x64-*.zip -t darwin -u eric.m.link@gmail.com --password $APPL_PASS",
    "clean": "rm -rf out package"
  },
  "dependencies": {
    "electron-window-state": "^5.0.3",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5",
    "mermaid": "^11.15.0",
    "node-emoji": "^2.2.0",
    "tmp": "^0.2.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-deb": "^7.5.0",
    "@electron-forge/maker-dmg": "^7.5.0",
    "@electron-forge/maker-pkg": "^7.5.0",
    "@electron-forge/maker-rpm": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@electron-forge/publisher-github": "^7.5.0",
    "electron": "^41.1.0"
  },
  "overrides": {
    "tar": "^7.4.3",
    "tmp": "^0.2.5",
    "@tootallnate/once": "^3.0.0",
    "http-proxy-agent": "^5.0.0"
  }
}
